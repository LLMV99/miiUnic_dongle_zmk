#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        Default_layer {
            display-name = "QWERTY";
            bindings = <
&kp TAB           &kp Q  &kp W    &kp E         &kp R         &kp T                            &kp Y       &kp U          &kp I      &kp O    &kp P           &kp ESCAPE
&kp LSHFT         &kp A  &lt 3 S  &lt 2 D       &lt 1 F       &kp G                            &kp H       &kp J          &kp K      &kp L    &kp SEMI        &kp RSHFT
&kp LEFT_CONTROL  &kp Z  &kp X    &kp C         &kp V         &kp B                            &kp N       &kp M          &kp COMMA  &kp DOT  &kp APOSTROPHE  &kp MINUS
                                  &kp LEFT_GUI  &kp LEFT_ALT  &kp SPACE  &kp C_MUTE  &kp C_PP  &kp RETURN  &kp BACKSPACE  &kp RALT
            >;

            sensor-bindings =
                <&inc_dec_kp C_VOLUME_DOWN C_VOLUME_UP>,
                <&inc_dec_kp PG_DN PG_UP>;
        };

        Num_layer {
            display-name = "Numbers";
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans                  &kp N7  &kp N8  &kp N9  &kp LS(RIGHT_BRACE)  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans                  &kp N4  &kp N5  &kp N6  &kp KP_PLUS          &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans                  &kp N1  &kp N2  &kp N3  &kp SLASH            &trans  &trans
                        &trans  &trans  &trans  &trans  &trans  &trans  &trans  &kp N0
            >;
        };

        Symbols {
            display-name = "Symbols";
            bindings = <
&kp TAB         &trans         &kp GRAVE       &kp RA(N1)    &kp LS(N6)     &kp LS(EQUAL)                        &kp RA(NUMBER_2)    &kp LS(N5)           &kp LS(N2)            &kp SLASH            &kp LS(SLASH)  &kp ESCAPE
&kp LEFT_SHIFT  &kp LS(COMMA)  &kp LS(PERIOD)  &trans        &kp LS(MINUS)  &kp LS(N1)                           &kp LS(N8)          &kp LS(N9)           &kp RA(APOS)          &kp RA(NON_US_HASH)  &kp RA(GRAVE)  &kp RSHFT
&kp LCTRL       &trans         &trans          &trans        &kp LS(N4)     &kp RA(N5)                           &kp RA(LEFT_BRACE)  &kp RA(RIGHT_BRACE)  &kp NON_US_BACKSLASH  &kp LS(NON_US_BSLH)  &kp LS(N7)     &studio_unlock
                                               &kp LEFT_GUI  &kp LALT       &kp SPACE      &kp C_MUTE  &kp C_PP  &kp RETURN          &kp BACKSPACE        &kp RALT
            >;
        };

        Functions {
            display-name = "Function";
            bindings = <
&kp F1          &kp F2  &kp F3  &kp F4     &kp F5     &kp F6                  &kp F7          &kp F8          &kp F9           &kp F10  &kp F11  &kp F12
&trans          &trans  &trans  &mkp LCLK  &mkp RCLK  &trans                  &trans          &kp UP_ARROW    &trans           &trans   &trans   &trans
&kp LEFT_SHIFT  &trans  &trans  &trans     &trans     &trans                  &kp LEFT_ARROW  &kp DOWN_ARROW  &kp RIGHT_ARROW  &trans   &trans   &trans
                                &trans     &mkp MCLK  &trans  &trans  &trans  &trans          &trans          &trans
            >;
        };
    };
};
